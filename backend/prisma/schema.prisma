// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // Switch to "mongodb" if using MongoDB
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  MANAGER
  USER
}

model User {
  id            String         @id @default(uuid()) // For MongoDB, use: @id @default(auto()) @map("_id") @db.ObjectId
  email         String         @unique
  password      String
  firstName     String?
  lastName      String?
  role          Role           @default(USER)
  isActive      Boolean        @default(true) // For MongoDB, use same type
  permissions   String[]       // Array of permissions. Supported by PostgreSQL, for others mapped via Role rules
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  refreshTokens RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid()) // For MongoDB, use: @id @default(auto()) @map("_id") @db.ObjectId
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  isRevoked Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}
