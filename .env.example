# ==============================================================================
# ENVIRONMENT VARIABLES TEMPLATE (fullstack-enterprise-template)
# ==============================================================================
# Copy this file to '.env' and fill in the values before starting development.

# --- SERVER CONFIGURATION ---
PORT=5000
NODE_ENV=development
API_PREFIX=/api/v1
CORS_ORIGIN=http://localhost:3000

# --- DATABASE CONFIGURATION ---
# PostgreSQL (default)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/enterprise_db?schema=public"

# MongoDB (Optional alternate setup, uncomment and configure if using MongoDB client/Prisma provider)
# MONGODB_URI="mongodb://root:example@localhost:27017/enterprise_db?authSource=admin"

# --- SECURITY & AUTHENTICATION ---
# Generate secure keys using: openssl rand -base64 32
JWT_SECRET="super-secret-access-token-key-change-in-production"
JWT_REFRESH_SECRET="super-secret-refresh-token-key-change-in-production"

# Expiration formats compatible with 'jsonwebtoken' library (e.g. 15m, 1h, 7d)
JWT_ACCESS_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# Cookie settings
COOKIE_SECURE=false # Set to true in production
COOKIE_SAME_SITE="lax" # Options: lax, strict, none

# --- LOGGING ---
# Options: error, warn, info, http, verbose, debug, silly
LOG_LEVEL="info"

# --- EMAIL CONFIGURATION (Nodemailer) ---
SMTP_HOST="smtp.mailtrap.io"
SMTP_PORT=2525
SMTP_USER="smtp-username"
SMTP_PASS="smtp-password"
SMTP_FROM="noreply@enterprise-app.com"

# --- FILE UPLOADS (Multer) ---
UPLOAD_MAX_SIZE=5242880 # 5MB in bytes
ALLOWED_FILE_TYPES="image/jpeg,image/png,image/webp,application/pdf"

# --- FRONTEND CONFIGURATION ---
# Prefix with VITE_ to expose to the React application
VITE_API_URL="http://localhost:5000/api/v1"
VITE_APP_NAME="Enterprise Application"
